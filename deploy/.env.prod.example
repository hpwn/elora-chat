# Production template (copy into deploy/.env.prod.dayo, deploy/.env.prod.test, and deploy/.env.prod.dylan)

# Global
TZ=America/Phoenix
LOG_LEVEL=info
DOCKER_UID=1000
DOCKER_GID=1000

# Images
ELORA_IMAGE=elora-chat:latest
GNASTY_IMAGE=<published-image-tag>

# Compose project/network
COMPOSE_PROJECT_NAME=elora_<target>
ELORA_DOCKER_NETWORK=elora-<target>-network
ELORA_ENV_FILE=deploy/.env.prod.<target>

# Shared data mount
ELORA_DATA_DIR=/data_<target>

# elora-chat
ELORA_HTTP_ADDR=0.0.0.0
ELORA_HTTP_PORT=8080
ELORA_DB_MODE=persistent
ELORA_DB_PATH=/data/gnasty.db
ELORA_SQLITE_JOURNAL_MODE=wal
ELORA_SQLITE_BUSY_TIMEOUT_MS=2000
ELORA_DB_MAX_CONNS=16
ELORA_DB_PRAGMAS_EXTRA=mmap_size=268435456,cache_size=-100000,temp_store=MEMORY

# Runtime authority + gnasty sync
ELORA_GNASTY_ADMIN_BASE=http://gnasty-harvester:8765
ELORA_TWITCH_WRITE_GNASTY_TOKENS=1
ELORA_TWITCH_SERVICE_REFRESH_INTERVAL_MINUTES=5
ELORA_TWITCH_SERVICE_REFRESH_BEFORE_EXPIRY_MINUTES=10

# CORS / public origins
ELORA_WS_ALLOWED_ORIGINS=https://<target>.<domain>
ELORA_ALLOWED_ORIGINS=https://<target>.<domain>

# Bootstrap defaults (used before /api/config persistence)
TWITCH_CHANNEL=
YOUTUBE_URL=
TWITCH_NICK=
VITE_PUBLIC_API_BASE=https://<target>.<domain>
VITE_PUBLIC_WS_URL=wss://<target>.<domain>/ws/chat
VITE_CHAT_DEBUG=0

# gnasty-harvester
GNASTY_HTTP_ADDR=0.0.0.0
GNASTY_HTTP_PORT=8765
GNASTY_SINK_SQLITE_PATH=/data/gnasty.db
GNASTY_TWITCH_TOKEN_FILE=/data/twitch_irc.pass
GNASTY_YT_API_KEY=

# Twitch OAuth
TWITCH_OAUTH_CLIENT_ID=
TWITCH_OAUTH_CLIENT_SECRET=
TWITCH_OAUTH_REDIRECT_URL=https://<target>.<domain>/callback/twitch

# Google OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=
