dayo.hayden.it.com {
  encode zstd gzip

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
    X-Frame-Options SAMEORIGIN
  }

  reverse_proxy elora_dayo-elora-chat:8080
}

elora.hayden.it.com {
  encode zstd gzip

  header {
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
    X-Frame-Options SAMEORIGIN
  }

  reverse_proxy elora_test-elora-chat:8080
}
