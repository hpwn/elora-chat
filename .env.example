# ============================
# Global
# ============================
TZ=America/Phoenix
LOG_LEVEL=info
DOCKER_UID=1000
DOCKER_GID=1000

# Docker images (override when publishing prebuilt images)
ELORA_IMAGE=elora-chat:latest
GNASTY_IMAGE=gnasty-chat:latest

# Project/network names
COMPOSE_PROJECT_NAME=elora
ELORA_DOCKER_NETWORK=elora-network

# Shared persistent volume path inside containers
ELORA_DATA_DIR=/data

# ============================
# elora-chat (API/WS + SQLite store)
# ============================
ELORA_HTTP_ADDR=0.0.0.0
ELORA_HTTP_PORT=8080

# SQLite persistent database
ELORA_DB_MODE=persistent
ELORA_DB_PATH=/data/gnasty.db
ELORA_SQLITE_JOURNAL_MODE=wal
ELORA_SQLITE_BUSY_TIMEOUT_MS=2000
ELORA_DB_MAX_CONNS=16
ELORA_DB_PRAGMAS_EXTRA=mmap_size=268435456,cache_size=-100000,temp_store=MEMORY

# Bootstrap defaults only (after first save in /api/config, Elora runtime config is authoritative)
ELORA_WS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,https://hpwn.github.io
ELORA_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,https://hpwn.github.io
ELORA_TAILER_ENABLED=1   # bootstrap default for gnasty SQLite -> WebSocket fan-out
TWITCH_CHANNEL=rifftrax
YOUTUBE_URL=
TWITCH_NICK=hp_az

# Shared-volume token handoff to gnasty
ELORA_TWITCH_WRITE_GNASTY_TOKENS=1   # when true the OAuth callback writes twitch_*.pass into ${ELORA_DATA_DIR}
ELORA_GNASTY_ADMIN_BASE=http://gnasty-harvester:8765 # runtime sync target for gnasty /admin/config
ELORA_GNASTY_RELOAD_URL=             # optional override; defaults to http://gnasty:${GNASTY_HTTP_PORT:-8765}/admin/twitch/reload
ELORA_TWITCH_SERVICE_REFRESH_INTERVAL_MINUTES=5         # backend ticker cadence for headless service token maintenance
ELORA_TWITCH_SERVICE_REFRESH_BEFORE_EXPIRY_MINUTES=10   # refresh when service token has <= N minutes remaining

# ============================
# gnasty-harvester (Twitch IRC + YouTube Live)
# ============================
GNASTY_HTTP_ADDR=0.0.0.0
GNASTY_HTTP_PORT=8765

# Deployment-specific sink path (shared volume handoff)
GNASTY_SINK_SQLITE_PATH=/data/gnasty.db
GNASTY_YT_API_KEY=

# ============================
# Twitch OAuth configuration (used by /auth/twitch)
# ============================
TWITCH_OAUTH_CLIENT_ID=                # required for OAuth handoff + gnasty token export
TWITCH_OAUTH_CLIENT_SECRET=            # required for OAuth handoff + gnasty token export
TWITCH_OAUTH_REDIRECT_URL=http://localhost:8080/auth/twitch/callback

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=

# ============================
# Frontend optional defaults used to seed backend runtime config before persistence
# ============================
VITE_PUBLIC_API_BASE=http://localhost:8080
VITE_PUBLIC_WS_URL=ws://localhost:8080/ws/chat
VITE_CHAT_DEBUG=0
